<?xml version="1.0" encoding="UTF-8"?>
<window id="startup">
  <onload>RunScript(special://skin/scripts/first_run.py)</onload>
  <onload condition="$EXP[EduteamoIsEnabled]">RunScript(plugin.video.eduteamo, None, &amp;update=)</onload>
  <onload>Setproperty(startup,si,home)</onload>
  <controls>
    <!-- <control type="videowindow" >
        <visible>True</visible>
        <include>FullScreenDimensions</include>
    </control> -->
    <control type="image">
      <width>$INFO[System.ScreenWidth]</width>
      <height>$INFO[System.ScreenHeight]</height>
      <texture colordiffuse="BFFFFFFF">special://skin/media/Eduteamo/startup.png</texture>
      <visible>True</visible>
    </control>
    

    <control type="group" description="debug">
      <visible>false</visible>
      <control type="label">
        <label>$INFO[Skin.TimerElapsedSecs(splashtimer)]</label>
        <top>200</top>
        <left>10</left>
      </control>
      <control type="label">
          <label>P3Updated == True</label>
          <visible>String.IsEqual(Window(startup).Property(P3Updated),true)</visible>
          <top>260</top>
          <left>10</left>
      </control>
      <control type="label">
          <label>P3Updated == False</label>
          <visible>!String.IsEqual(Window(startup).Property(P3Updated),true)</visible>
          <top>260</top>
          <left>10</left>
      </control>
    </control>
  </controls>
</window>